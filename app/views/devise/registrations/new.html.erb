<% content_for(:auth_header) do %>
  <h2 class="mt-10 text-center text-2xl font-bold leading-9 tracking-tight text-gray-900">Create your account</h2>
  <p class="mt-2 text-center text-sm text-gray-600">
  Have an account already?
    <%- if controller_name != 'sessions' %>
      <%= link_to "Log in", new_session_path(resource_name), class: "font-medium text-indigo-600 hover:text-indigo-500"%><br />
    <% end %>
  </p>
<% end %>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="mb-6">
    <%= f.label :first_name, class: label_class %>
    <div class="mt-1">
      <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name", class: input_class %>
    </div>
  </div>

  <div class="mb-6">
    <%= f.label :last_name, class: label_class %>
    <div class="mt-1">
      <%= f.text_field :last_name, autocomplete: "family-name", class: input_class %>
    </div>
  </div>

  <div class="mb-6">
    <%= f.label :email, class: label_class %>
    <div class="mt-1">
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: input_class %>
    </div>
  </div>

  <div class="mb-6">
    <%= f.label :password, class: label_class %>
    <div class="mt-1">
      <%= f.password_field :password, autocomplete: "new-password", class: input_class %>
    </div>
    <% if @minimum_password_length %>
    <em class="mt-1 text-sm text-gray-500">(<%= @minimum_password_length %> characters minimum)</em>
    <% end %><br />
  </div>

  <div class="mb-6">
    <%= f.label :password_confirmation, class: label_class %>
    <div class="mt-1">
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: input_class %>
    </div>
  </div>

  <div>
    <%= f.submit "Sign up", class: form_button_class %>
  </div>
<% end %>

<%#= render "devise/shared/links" %>
